{
  "name": "goodgrades",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "lint": "biome check .",
    "format": "biome check --write .",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run --config scripts/vitest.config.ts && pnpm -r test",
    "status": "node scripts/status.mjs",
    "uptime": "node scripts/uptime-check.mjs",
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "typescript": "5.6.3",
    "vitest": "2.1.8"
  }
}
